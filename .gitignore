# ==============================
# OS files
# ==============================
.DS_Store
Thumbs.db
ehthumbs.db
# macOS custom folder icon file (Icon with carriage return)
Icon

# Exclude our Icons folder from being ignored
!app/public/assets/Icons/

# ==============================
# Editor / IDE
# ==============================
.vscode/
.idea/
*.iml

# ==============================
# Composer
# ==============================
composer.phar
/vendor/
/app/vendor/
/vendor-bin/**/vendor/

# ==============================
# Environment files (keep examples)
# ==============================
.env
.env.*
!.env.example
!/app/.env.example

# ==============================
# Logs and caches
# ==============================
*.log
logs/
tmp/
temp/
cache/
storage/
var/
app/storage/
app/cache/
app/var/
.phpunit.result.cache
coverage/
!app/storage/
app/storage/*
!app/storage/.gitkeep
!app/storage/cache/
app/storage/cache/*
!app/storage/cache/.gitkeep
app/public/assets/tickets/*
!app/public/assets/tickets/.gitkeep

# ==============================
# Node (if present)
# ==============================
node_modules/

# ==============================
# Docker
# ==============================
docker-compose.override.yml

# Named volumes (safety, if ever mapped locally)
mysqldata/

# ==============================
# Temporary / runtime files
# ==============================
*.tmp
*.bak
*.swp
*.cache
